# ReNova backend local environment example.
# Copy values into your shell, IDE run configuration, or an ignored local env file.

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=novacart
DB_USERNAME=""
DB_PASSWORD=""

# Use a long random value for any shared or deployed environment.
JWT_EXPIRATION_MINUTES=120
SESSION_COOKIE_SECURE=false

# Comma-separated list of allowed browser origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Backend HTTP port.
SERVER_PORT=8080

# Private S3-compatible object storage. Use separate external upload URL in containers.
OBJECT_STORAGE_INTERNAL_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_UPLOAD_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=""
OBJECT_STORAGE_SECRET_KEY=""
OBJECT_STORAGE_BUCKET=renova-media
PUBLIC_API_BASE_URL=http://localhost:8080/api

# Optional local-only sample data. Leave the demo profile disabled by default.
# SPRING_PROFILES_ACTIVE=demo
# RENOVA_DEMO_PASSWORD=<choose-at-least-12-characters>

# Kept last so automated scanners cannot join an intentional empty value with the next setting.
JWT_SECRET=""
