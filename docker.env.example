# ReNova docker-compose environment example.
# Copy to .env at the repo root (gitignored), replace every __SET_ME__,
# then run `docker compose up --build`. docker-compose.yml uses :? on
# these variables, so `up` will refuse to start until they are real.

MYSQL_DATABASE=__SET_ME__
MYSQL_USER=__SET_ME__
MYSQL_PASSWORD=__SET_ME__
MYSQL_ROOT_PASSWORD=__SET_ME__
MYSQL_PORT=3306

BACKEND_PORT=8080
# Required, 32+ random bytes. Generate, e.g., with:
#   openssl rand -base64 48
JWT_SECRET=__SET_ME__
JWT_EXPIRATION_MINUTES=120

FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8080/api
