# NovaCart Docker Compose environment example.
# Copy this file to .env and fill every blank before running Docker Compose.
# Generate unique values; never reuse production credentials in local development.

MYSQL_DATABASE=novacart
MYSQL_USER=""
MYSQL_PASSWORD=""
MYSQL_ROOT_PASSWORD=""
MYSQL_PORT=3306

BACKEND_PORT=8080
JWT_EXPIRATION_MINUTES=120
SESSION_COOKIE_SECURE=false

FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8080/api

# Kept last so automated scanners cannot join an intentional empty value with the next setting.
JWT_SECRET=""
