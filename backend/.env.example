# NovaCart backend local environment example.
# Copy values into your shell, IDE run configuration, or an ignored local env file.

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=novacart
DB_USERNAME=novacart_user
DB_PASSWORD=novacart_password

# Use a long random value for any shared or deployed environment.
JWT_SECRET=replace-with-a-long-random-secret-for-local-development
JWT_EXPIRATION_MINUTES=120

# Comma-separated list of allowed browser origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Backend HTTP port.
SERVER_PORT=8080
