# ReNova backend local environment example.
# Copy to backend/.env (gitignored) and replace every __SET_ME__ with a
# real value. The backend refuses to start outside dev/test/demo profiles
# unless JWT_SECRET is a real 32+ byte non-placeholder value.

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=__SET_ME__
DB_USERNAME=__SET_ME__
DB_PASSWORD=__SET_ME__

# Required: at least 32 random bytes. Generate one with, e.g.:
#   openssl rand -base64 48
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=__SET_ME__
JWT_EXPIRATION_MINUTES=120

# Comma-separated list of allowed browser origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Backend HTTP port.
SERVER_PORT=8080
